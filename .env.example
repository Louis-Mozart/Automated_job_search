# ─────────────────────────────────────────────────────────────────
# AutoJob Finder – Environment Variables
# Copy this file to .env and fill in your keys.
# The app works without any keys (uses Remotive free API),
# but more keys = more job sources & smarter matching.
# ─────────────────────────────────────────────────────────────────

# ── OpenAI ──────────────────────────────────────────────────────
# Used for: smart CV parsing, semantic job matching
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Model to use for CV analysis (gpt-4o-mini is cheap & fast)
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── RapidAPI / JSearch ──────────────────────────────────────────
# Aggregates LinkedIn, Indeed, Glassdoor, ZipRecruiter & more
# Free tier: 200 requests/month
# Get key: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=

# ── Adzuna ──────────────────────────────────────────────────────
# Large job board with a generous free tier (250 req/day)
# Register: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Country code for Adzuna search: us, gb, de, fr, au, ca, nl, sg
ADZUNA_COUNTRY=us

# ── App Defaults ────────────────────────────────────────────────
DEFAULT_K=10
MAX_JOBS_TO_FETCH=600
